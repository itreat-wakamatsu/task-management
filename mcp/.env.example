# Supabase（必須）
# SupabaseダッシュボードのProject Settings > API から取得
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 対象ユーザーのID（必須）
# Supabase ダッシュボード > Authentication > Users から確認
SUPABASE_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ─── Google Calendar 設定（任意）───────────────────────────
# 【推奨】Google OAuth クライアントID / シークレット
#   設定すると refresh_token を使って自動更新されるため、
#   ユーザーが毎回トークンを更新する必要がなくなります。
#
#   取得方法:
#     Google Cloud Console → API とサービス → 認証情報
#     Supabase の Google OAuth に使用している OAuth 2.0 クライアントの値
#
# SupabaseダッシュボードのAuthentication > Providers > Googleにある
# Client IDとClient Secretをそのまま使用できます
GOOGLE_CLIENT_ID=xxxxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 【補助】アクセストークンを直接指定（GOOGLE_CLIENT_ID 未設定時のフォールバック）
# ※ 1時間で期限切れになるため非推奨
# GOOGLE_ACCESS_TOKEN=ya29.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 勤務時間設定（任意）
# create_calendar_event 時の予定作成範囲に使用
WORK_START_HOUR=9
WORK_END_HOUR=18
