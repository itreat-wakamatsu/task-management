# Supabase（必須）
# SupabaseダッシュボードのProject Settings > API から取得
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 対象ユーザーのID（必須）
# Supabase ダッシュボード > Authentication > Users から確認
SUPABASE_USER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google Calendar アクセストークン（任意）
# get_calendar_events / create_calendar_event ツール使用時に必要
# 取得方法: ブラウザでアプリにログイン後、DevTools > Application >
#   Local Storage > supabase.auth.token を開き
#   "provider_token" の値をここに貼り付ける
# ※ アクセストークンは1時間で期限切れになります
GOOGLE_ACCESS_TOKEN=ya29.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 勤務時間設定（任意）
# create_calendar_event 時の予定作成範囲に使用
WORK_START_HOUR=9
WORK_END_HOUR=18
